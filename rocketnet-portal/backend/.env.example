# RocketNet Portal Backend Configuration

# Application
DEBUG=true
SECRET_KEY=your-secret-key-minimum-32-characters-long
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost/rocketnet_portal

# Redis
REDIS_URL=redis://localhost:6379

# Splynx Configuration
SPLYNX_URL=https://your-splynx-instance.com
SPLYNX_API_KEY=your_splynx_api_key
SPLYNX_API_SECRET=your_splynx_api_secret
SPLYNX_TIMEOUT=30

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
ALLOWED_HOSTS=*

# Features
ENABLE_SPEED_TEST=true
RETENTION_FEE_AMOUNT=25.00
MAX_SPEED_TESTS_PER_DAY=5

# External Services
SPEED_TEST_PROVIDER=ookla
SPEED_TEST_API_KEY=

# Email (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Monitoring (Optional)
SENTRY_DSN=
LOG_LEVEL=INFO